# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Supabase — find these in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# LLM Provider — "lmstudio" (dev, free) or "anthropic" (prod)
LLM_PROVIDER=lmstudio

# LM Studio (dev)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3-8b

# Anthropic (prod) — only needed when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
